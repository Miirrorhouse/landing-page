            {
              "type": "text",
              "id": "T4Rny",
              "fill": "#727272",
              "content": "YOUR INSTRUCTOR",
              "fontFamily": "Host Grotesk",
              "fontSize": 10,
              "fontWeight": "700",
              "letterSpacing": 2.5
            },
            {
              "type": "text",
              "id": "9D5er",
              "fill": "#1C1C1C",
              "content": "Meet Nonna Patrizia",
              "lineHeight": 0.95,
              "fontFamily": "Source Serif Pro",
              "fontSize": 38,
              "fontWeight": "normal",
              "letterSpacing": -1.5
            },
            {
              "type": "text",
              "id": "lqj0V",
              "fill": "#727272",
              "content": "Born and raised in Palombara Sabina, a hilltop village outside Rome, Nonna Patrizia has spent her whole life making these ancient pasta recipes.",
              "lineHeight": 1.65,
              "fontFamily": "Host Grotesk",
              "fontSize": 15,
              "fontWeight": "300"
            },
            {
              "type": "frame",
              "id": "DDzG1",
              "name": "mobQuote",
              "fill": "#F6EDE3",
              "cornerRadius": 12,
              "layout": "vertical",
              "gap": 10,
              "padding": 20,
              "children": [
                {
                  "type": "text",
                  "id": "pBpGa",
                  "fill": "#1C1C1C",
                  "content": "“Every pasta has a story. Gricia is the grandmother of them all. I cannot wait to share it with you.”",
                  "lineHeight": 1.55,
                  "fontFamily": "Source Serif Pro",
                  "fontSize": 17,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "EwUBZ",
                  "fill": "#727272",
                  "content": "— Nonna Patrizia",
                  "fontFamily": "Host Grotesk",
                  "fontSize": 12,
                  "fontWeight": "600"
                }
              ]
            },
